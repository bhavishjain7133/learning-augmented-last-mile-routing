__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
.ipynb_checkpoints/
.coverage

# The Amazon dataset is downloaded separately and must not be committed.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Generated artifacts are ignored by default. Compact evidence is whitelisted.
artifacts/*
!artifacts/.gitkeep
!artifacts/data_audit/
!artifacts/data_audit/route_profile.json
!artifacts/data_audit/routes_by_station.png
!artifacts/data_audit/stops_per_route.png
!artifacts/confirmatory_results/
!artifacts/confirmatory_results/**
!artifacts/research_story/
!artifacts/research_story/**
!artifacts/travel_time_experiment/
artifacts/travel_time_experiment/*
!artifacts/travel_time_experiment/run_metadata.json
!artifacts/travel_time_experiment/validation_weight_summary.csv

notebooks/executed/*
!notebooks/executed/.gitkeep
